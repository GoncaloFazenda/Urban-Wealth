# Supabase / PostgreSQL (connection pooling)
DATABASE_URL="postgresql://postgres.your-project:[YOUR-PASSWORD]@your-host:6543/postgres?pgbouncer=true"

# Direct connection (for migrations)
DIRECT_URL="postgresql://postgres.your-project:[YOUR-PASSWORD]@your-host:5432/postgres"

# JWT secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
