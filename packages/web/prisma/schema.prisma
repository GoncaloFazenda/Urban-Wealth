generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(uuid())
  fullName     String       @map("full_name")
  email        String       @unique
  passwordHash String       @map("password_hash")
  role         UserRole     @default(USER)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  investments  Investment[]
  watchlist    Watchlist[]
  wallet       Wallet?
  yieldPayouts YieldPayout[]
  listings      Listing[]       @relation("UserListings")
  purchases     Trade[]         @relation("UserPurchases")
  sales         Trade[]         @relation("UserSales")
  notifications Notification[]

  @@map("users")
}

model Property {
  id                    String         @id @default(uuid())
  title                 String
  location              String
  photoUrls             String[]       @map("photo_urls")
  totalValue            Float          @map("total_value")
  funded                Float          @default(0)
  annualYield           Float          @map("annual_yield")
  projectedAppreciation Float          @map("projected_appreciation")
  status                PropertyStatus @default(OPEN)
  description           String
  availableShares       Int            @map("available_shares")
  platformFee           Float          @default(0.015) @map("platform_fee")
  createdAt             DateTime       @default(now()) @map("created_at")
  investments           Investment[]
  watchlist             Watchlist[]
  listings              Listing[]
  trades                Trade[]

  @@map("properties")
}

model Investment {
  id                     String           @id @default(uuid())
  userId                 String           @map("user_id")
  propertyId             String           @map("property_id")
  amount                 Float
  ownershipPercentage    Float            @map("ownership_percentage")
  estimatedAnnualIncome  Float            @map("estimated_annual_income")
  estimatedAppreciationGain Float         @map("estimated_appreciation_gain")
  platformFee            Float            @map("platform_fee")
  status                 InvestmentStatus @default(COMPLETED)
  yieldStartDate         DateTime?        @map("yield_start_date")
  createdAt              DateTime         @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  payouts  YieldPayout[]
  listings Listing[]

  @@map("investments")
}

model RefreshTokenDenylist {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@map("refresh_token_denylist")
}

enum UserRole {
  USER
  ADMIN
}

enum PropertyStatus {
  OPEN
  COMING_SOON
  FUNDED
}

model Watchlist {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  propertyId String   @map("property_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
  @@map("watchlist")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model YieldPayout {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  investmentId String   @map("investment_id")
  amount       Float
  month        DateTime
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id])
  investment Investment @relation(fields: [investmentId], references: [id])

  @@unique([investmentId, month])
  @@map("yield_payouts")
}

enum InvestmentStatus {
  COMPLETED
  PENDING
  PARTIALLY_SOLD
  SOLD
}

model Listing {
  id              String        @id @default(uuid())
  sellerId        String        @map("seller_id")
  investmentId    String        @map("investment_id")
  propertyId      String        @map("property_id")
  sharesAmount    Float         @map("shares_amount")
  ownershipPct    Float         @map("ownership_pct")
  askPrice        Float         @map("ask_price")
  pricePerPercent Float         @map("price_per_percent")
  status          ListingStatus @default(ACTIVE)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  seller     User       @relation("UserListings", fields: [sellerId], references: [id])
  investment Investment @relation(fields: [investmentId], references: [id])
  property   Property   @relation(fields: [propertyId], references: [id])
  trade      Trade?

  @@map("listings")
}

model Trade {
  id          String      @id @default(uuid())
  listingId   String      @unique @map("listing_id")
  buyerId     String      @map("buyer_id")
  sellerId    String      @map("seller_id")
  propertyId  String      @map("property_id")
  amount      Float
  platformFee Float       @map("platform_fee")
  status      TradeStatus @default(COMPLETED)
  createdAt   DateTime    @default(now()) @map("created_at")

  listing  Listing  @relation(fields: [listingId], references: [id])
  buyer    User     @relation("UserPurchases", fields: [buyerId], references: [id])
  seller   User     @relation("UserSales", fields: [sellerId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@map("trades")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

enum TradeStatus {
  COMPLETED
  PENDING
}

enum NotificationType {
  LISTING_PURCHASED
  WATCHLIST_LISTING
}
